# Port the signaling server listens on (Render/Railway set this automatically).
PORT=3001

# Comma-separated list of frontend origins allowed to connect.
# Local dev (Vite): http://localhost:5173
# Production: https://your-frontend.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Max peers per room. 2 = strict 1-to-1 sender/receiver (default).
ROOM_CAPACITY=2

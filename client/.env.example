# URL of the Beam signaling server.
# Local dev: http://localhost:3001
# Production: https://your-signaling-server.onrender.com
VITE_SIGNALING_URL=http://localhost:3001

# Optional: a TURN server for peers behind strict/symmetric NATs.
# Public STUN (built in) is enough for most networks; TURN is the fallback
# relay when a direct path cannot be established. Leave blank to skip.
# VITE_TURN_URL=turn:your-turn-host:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
